{
  "chat.tools.terminal.autoApprove": {
    "flutter": true,
    "dart": true,
    "pre-commit": true,
    "mkdir": true,
    "touch": true,
    "hexdump": true,
    "clang++": true,
    "./trace_decomp": true,
    "diff": true,
    "mv": true,
    "printf": true,
    "awk": true
  },
  "dart.lineLength": 80,
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.rulers": [
      80
    ]
  }
}
